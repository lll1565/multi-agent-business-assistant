# Multi-Agent System Configuration
# Copy to .env for local use — NEVER commit .env (listed in .gitignore).

OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://api.minimaxi.com/v1
OPENAI_MODEL=MiniMax-M2.7

# Project paths (optional — needed for wheel installs or custom data dirs)
# PROJECT_ROOT=/path/to/multi_agent_system
# DATA_DIR=/path/to/data

# Runtime mode: development | production
APP_ENV=development

# SQLite
DB_PATH=data/demo.db
CHAT_DB_PATH=data/chat.db

# Agent routing / streaming
ENABLE_HARD_ROUTE=true
# SSE reply buffer chunk size (application layer — not LLM stream chunk size)
REPLY_BUFFER_CHUNK_SIZE=1
# Legacy alias (still supported):
# STREAM_DELTA_CHUNK_SIZE=1

# CORS (comma-separated; see backend/config/ports.json for frontend port)
CORS_ORIGINS=http://localhost:5143,http://127.0.0.1:5143

# Production security (optional in dev; recommended in production)
# API_AUTH_KEY=replace-with-long-random-string
# CHAT_RATE_LIMIT_PER_MINUTE=30
# TRUSTED_HOSTS=your-domain.example,localhost
# SERVE_FRONTEND=true

# Backend thread pool for agent calls
AGENT_EXECUTOR_WORKERS=2

# Logging (LOG_FORMAT=json for JSON log lines)
LOG_LEVEL=INFO
LOG_FILE=data/logs/app.log
LOG_TO_CONSOLE=true
LOG_FORMAT=

# LangSmith — LLM / LangGraph trace (https://smith.langchain.com)
LANGSMITH_TRACING=false
# LANGSMITH_API_KEY=your_key
# LANGSMITH_PROJECT=multi-agent-system
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# OpenTelemetry — HTTP + Agent spans (console or OTLP)
OTEL_ENABLED=false
OTEL_SERVICE_NAME=multi-agent-chat
# OTEL_EXPORTER_ENDPOINT=http://127.0.0.1:4318/v1/traces

# Frontend build (Vite) — must match API_AUTH_KEY when auth is enabled
# VITE_API_KEY=replace-with-long-random-string
